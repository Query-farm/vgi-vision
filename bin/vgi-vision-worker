#!/usr/bin/env bash
# Launch wrapper so DuckDB's vgi extension can spawn this Python worker via a plain
# filesystem LOCATION:
#   ATTACH 'vision' (TYPE vgi, LOCATION '/path/to/vgi-vision/bin/vgi-vision-worker');
#
# The worker speaks Arrow IPC over stdin/stdout (Worker.run()). `uv run` resolves the
# project's environment (vgi-python + onnxruntime + pillow + numpy + huggingface-hub)
# and execs the console script; uv's own diagnostics go to stderr, so stdout stays a
# clean Arrow IPC stream.
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec uv run --project "$REPO_ROOT" --quiet vgi-vision-worker "$@"
